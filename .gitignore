# =============================================================================
# Logs & debug output
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =============================================================================
# Frontend (Vite / Bun / Vue)
# =============================================================================
node_modules/
dist/
dist-ssr/
*.local

# Bun caches & alternate lockfile binary (we ship `bun.lock` text format)
.bun/
bun.lockb

# Vite's local cache between dev sessions
.vite/

# Auto-generated by Nuxt UI's Vite plugin
# (unplugin-auto-import + unplugin-vue-components)
auto-imports.d.ts
components.d.ts

# Artifacts from `vue-tsc -b` (it emits these alongside vite.config.ts)
vite.config.d.ts
vite.config.js
*.tsbuildinfo

# Test / coverage (none today but reserved)
coverage/
*.lcov

# =============================================================================
# Rust / Tauri
# =============================================================================
src-tauri/target/
src-tauri/gen/schemas/
src-tauri/WixTools/

# Local Cargo overrides — sometimes added during debugging, never to be shared
src-tauri/.cargo/

# Tauri-generated macOS app bundle (lives under target/, but be explicit)
src-tauri/**/*.app/

# Portable-mode `config.json` written next to the dev exe during testing
src-tauri/target/**/config.json

# =============================================================================
# Editors / IDEs
# =============================================================================
.vscode/*
!.vscode/extensions.json
.history/

.idea/
*.iml

# Vim / Neovim swap files (and Session.vim)
*.sw?
Session.vim

# =============================================================================
# Env / secrets — never commit
# =============================================================================
.env
.env.local
.env.*.local
secrets/
*.pem
*.key

# Tauri updater signing keys (the public key is in tauri.conf.json, the
# private key MUST stay out of the repo)
*.key.pem

# =============================================================================
# OS junk
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.AppleDB
.AppleDesktop
.LSOverride
.apdisk
Network Trash Folder
Temporary Items

# Windows
Thumbs.db
ehthumbs.db
ehthumbs_vista.db
desktop.ini
$RECYCLE.BIN/
*.suo
*.ntvs*
*.njsproj
*.sln
