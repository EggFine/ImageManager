{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "core:window:allow-is-maximized",
    "core:event:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://**" }, { "url": "http://**" }]
    },
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "fs:allow-read-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$EXE/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPDATA/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$PICTURE/**" },
        { "path": "$RESOURCE/**" },
        { "path": "$TEMP/**" },
        { "path": "$HOME/**" }
      ]
    },
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [{ "url": "https://**" }, { "url": "http://**" }]
    },
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "os:default"
  ]
}
